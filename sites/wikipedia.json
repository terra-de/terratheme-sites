{
  "version": 2,
  "match": ["*://*.wikipedia.org/*"],
  "rules": [
    {
      "selector": ":root",
      "important": true,
      "set": {
        "--background-color-base": "var(--tt-base)",
        "--background-color-neutral": "var(--tt-high)",
        "--background-color-neutral-subtle": "var(--tt-high)",
        "--background-color-interactive": "var(--tt-low)",
        "--background-color-interactive--hover": "var(--tt-base)",
        "--background-color-interactive--active": "var(--tt-high)",
        "--background-color-interactive-subtle": "var(--tt-low)",
        "--background-color-interactive-subtle--hover": "var(--tt-low)",
        "--background-color-interactive-subtle--active": "var(--tt-base)",
        "--background-color-disabled": "var(--tt-low)",
        "--background-color-disabled-subtle": "var(--tt-low)",
        "--background-color-inverted": "var(--tt-inverse-base)",
        "--background-color-backdrop-dark": "var(--tt-scrim)",
        "--background-color-backdrop-light": "transparent",
        "--background-color-tab-list-item-framed--hover": "color-mix(in srgb, var(--tt-standard) 5%, transparent)",
        "--background-color-tab-list-item-framed--active": "color-mix(in srgb, var(--tt-base) 100%, transparent)",

        "--color-base": "var(--tt-standard)",
        "--color-base--hover": "var(--tt-standard)",
        "--color-base--subtle": "var(--tt-muted)",
        "--color-subtle": "var(--tt-muted)",
        "--color-emphasized": "var(--tt-standard)",
        "--color-disabled": "var(--tt-muted)",
        "--color-disabled-emphasized": "var(--tt-muted)",
        "--color-inverted": "var(--tt-inverse-standard)",
        "--color-placeholder": "var(--tt-muted)",
        "--color-notice": "var(--tt-muted)",
        "--color-neutral": "var(--tt-muted)",

        "--accent-color-base": "var(--tt-c4)",
        "--color-link": "var(--tt-c4)",
        "--color-link--hover": "color-mix(in srgb, var(--tt-c4) 80%, var(--tt-standard))",
        "--color-link--active": "color-mix(in srgb, var(--tt-c4) 70%, var(--tt-standard))",
        "--color-link--focus": "var(--tt-c4)",
        "--color-link--visited": "color-mix(in srgb, var(--tt-c4) 60%, var(--tt-muted))",
        "--color-link--visited--hover": "color-mix(in srgb, var(--tt-c4) 50%, var(--tt-muted))",
        "--color-link--visited--active": "color-mix(in srgb, var(--tt-c4) 40%, var(--tt-muted))",
        "--color-visited": "color-mix(in srgb, var(--tt-c4) 60%, var(--tt-muted))",
        "--color-visited--hover": "color-mix(in srgb, var(--tt-c4) 50%, var(--tt-muted))",
        "--color-visited--active": "color-mix(in srgb, var(--tt-c4) 40%, var(--tt-muted))",

        "--color-link-red": "var(--tt-error)",
        "--color-link-red--hover": "color-mix(in srgb, var(--tt-error) 80%, var(--tt-standard))",
        "--color-link-red--visited": "color-mix(in srgb, var(--tt-error) 60%, var(--tt-muted))",
        "--color-link-red--visited--hover": "color-mix(in srgb, var(--tt-error) 50%, var(--tt-muted))",
        "--color-link-red--visited--active": "color-mix(in srgb, var(--tt-error) 40%, var(--tt-muted))",
        "--color-link-red--active": "color-mix(in srgb, var(--tt-error) 60%, var(--tt-standard))",
        "--color-link-red--focus": "var(--tt-c4)",

        "--color-progressive": "var(--tt-c4)",
        "--color-progressive--hover": "color-mix(in srgb, var(--tt-c4) 80%, var(--tt-standard))",
        "--color-progressive--active": "color-mix(in srgb, var(--tt-c4) 60%, var(--tt-standard))",
        "--color-progressive--focus": "var(--tt-c4)",
        "--background-color-progressive": "var(--tt-c4)",
        "--background-color-progressive--hover": "color-mix(in srgb, var(--tt-c4) 88%, var(--tt-standard))",
        "--background-color-progressive--active": "color-mix(in srgb, var(--tt-c4) 76%, var(--tt-standard))",
        "--background-color-progressive--focus": "var(--tt-c4)",
        "--background-color-progressive-subtle": "color-mix(in srgb, var(--tt-c4) 12%, transparent)",
        "--background-color-progressive-subtle--hover": "color-mix(in srgb, var(--tt-c4) 18%, transparent)",
        "--background-color-progressive-subtle--active": "color-mix(in srgb, var(--tt-c4) 30%, transparent)",

        "--color-destructive": "var(--tt-error)",
        "--color-destructive--hover": "color-mix(in srgb, var(--tt-error) 80%, var(--tt-standard))",
        "--color-destructive--active": "color-mix(in srgb, var(--tt-error) 60%, var(--tt-standard))",
        "--color-destructive--focus": "var(--tt-c4)",
        "--color-destructive--visited": "color-mix(in srgb, var(--tt-error) 60%, var(--tt-muted))",
        "--color-destructive--visited--hover": "color-mix(in srgb, var(--tt-error) 50%, var(--tt-muted))",
        "--color-destructive--visited--active": "color-mix(in srgb, var(--tt-error) 40%, var(--tt-muted))",
        "--background-color-destructive": "var(--tt-error)",
        "--background-color-destructive--hover": "color-mix(in srgb, var(--tt-error) 88%, var(--tt-standard))",
        "--background-color-destructive--active": "color-mix(in srgb, var(--tt-error) 76%, var(--tt-standard))",
        "--background-color-destructive--focus": "var(--tt-c4)",
        "--background-color-destructive-subtle": "color-mix(in srgb, var(--tt-error) 12%, transparent)",
        "--background-color-destructive-subtle--hover": "color-mix(in srgb, var(--tt-error) 18%, transparent)",
        "--background-color-destructive-subtle--active": "color-mix(in srgb, var(--tt-error) 30%, transparent)",

        "--color-error": "var(--tt-error)",
        "--color-error--hover": "color-mix(in srgb, var(--tt-error) 80%, var(--tt-standard))",
        "--color-error--active": "color-mix(in srgb, var(--tt-error) 60%, var(--tt-standard))",
        "--background-color-error": "var(--tt-error)",
        "--background-color-error--hover": "color-mix(in srgb, var(--tt-error) 88%, var(--tt-standard))",
        "--background-color-error--active": "color-mix(in srgb, var(--tt-error) 76%, var(--tt-standard))",
        "--background-color-error-subtle": "color-mix(in srgb, var(--tt-error) 12%, transparent)",
        "--background-color-error-subtle--hover": "color-mix(in srgb, var(--tt-error) 18%, transparent)",
        "--background-color-error-subtle--active": "color-mix(in srgb, var(--tt-error) 30%, transparent)",

        "--color-success": "var(--tt-c2)",
        "--background-color-success-subtle": "color-mix(in srgb, var(--tt-c2) 12%, transparent)",

        "--color-warning": "var(--tt-c1)",
        "--background-color-warning-subtle": "color-mix(in srgb, var(--tt-c1) 12%, transparent)",

        "--color-icon-progressive": "var(--tt-c4)",
        "--color-icon-error": "var(--tt-error)",
        "--color-icon-success": "var(--tt-c2)",
        "--color-icon-warning": "var(--tt-c1)",
        "--color-icon-notice": "var(--tt-muted)",

        "--color-content-added": "color-mix(in srgb, var(--tt-c2) 80%, transparent)",
        "--color-content-removed": "color-mix(in srgb, var(--tt-error) 80%, transparent)",
        "--background-color-content-added": "color-mix(in srgb, var(--tt-c2) 25%, transparent)",
        "--background-color-content-removed": "color-mix(in srgb, var(--tt-c1) 25%, transparent)",

        "--background-color-target-text": "color-mix(in srgb, var(--tt-c1) 20%, transparent)",

        "--border-color-base": "var(--tt-outline)",
        "--border-color-subtle": "var(--tt-outline-variant)",
        "--border-color-muted": "var(--tt-outline-variant)",
        "--border-color-emphasized": "var(--tt-outline)",
        "--border-color-divider": "var(--tt-outline-variant)",
        "--border-color-interactive": "var(--tt-outline)",
        "--border-color-interactive--hover": "var(--tt-outline)",
        "--border-color-interactive--active": "var(--tt-standard)",
        "--border-color-disabled": "var(--tt-outline-variant)",
        "--border-color-transparent": "transparent",
        "--border-color-input-binary": "var(--tt-outline)",
        "--border-color-input-binary--checked": "var(--tt-c4)",
        "--border-color-input-binary--hover": "var(--tt-c4)",
        "--border-color-input-binary--focus": "var(--tt-c4)",
        "--border-color-progressive": "var(--tt-c4)",
        "--border-color-progressive--hover": "var(--tt-c4)",
        "--border-color-progressive--active": "var(--tt-standard)",
        "--border-color-progressive--focus": "var(--tt-c4)",
        "--border-color-error": "var(--tt-error)",
        "--border-color-error--hover": "color-mix(in srgb, var(--tt-error) 80%, var(--tt-standard))",
        "--border-color-error--active": "var(--tt-standard)",
        "--border-color-success": "var(--tt-c2)",
        "--border-color-warning": "var(--tt-c1)",
        "--border-color-warning--hover": "var(--tt-c1)",
        "--border-color-warning--active": "var(--tt-standard)",
        "--border-color-notice": "var(--tt-muted)",

        "--outline-color-progressive--focus": "var(--tt-c4)"
      }
    }
  ]
}
