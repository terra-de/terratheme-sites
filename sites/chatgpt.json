{
  "version": 2,
  "match": ["*://chatgpt.com/*"],
  "rules": [
    {
      "selector": ":root",
      "important": true,
      "set": {
        "--main-surface-background": "var(--tt-low)",
        "--main-surface-primary": "var(--tt-low)",
        "--main-surface-secondary": "var(--tt-base)",
        "--main-surface-tertiary": "var(--tt-high)",
        "--message-surface": "var(--tt-low)",
        "--sidebar-bg": "var(--tt-low)",
        "--sidebar-surface-primary": "var(--tt-low)",
        "--sidebar-surface-secondary": "var(--tt-base)",
        "--sidebar-surface-tertiary": "var(--tt-high)",
        "--sidebar-mask-bg": "var(--tt-low)",
        "--surface-primary": "var(--tt-low)",
        "--surface-secondary": "var(--tt-base)",
        "--surface-tertiary": "var(--tt-high)",
        "--canvas-background": "var(--tt-bottom)",
        "--thread-background": "var(--tt-low)",
        "--bg-primary": "var(--tt-base)",
        "--bg-primary-hover": "var(--tt-low)",
        "--bg-primary-disabled": "color-mix(in srgb, var(--tt-base) 50%, transparent)",
        "--bg-elevated-secondary": "var(--tt-high)",
        "--bg-scrim": "var(--tt-scrim)",
        "--bg-danger": "var(--tt-error)",
        "--bg-success": "var(--tt-c2)",
        "--bg-warning": "var(--tt-c1)",
        "--bg-contrast": "var(--tt-inverse-base)",
        "--text-primary": "var(--tt-standard)",
        "--text-secondary": "var(--tt-muted)",
        "--text-tertiary": "var(--tt-muted)",
        "--text-quaternary": "color-mix(in srgb, var(--tt-muted) 60%, transparent)",
        "--text-danger": "var(--tt-error)",
        "--text-danger-on-danger": "var(--tt-on-error)",
        "--text-success": "var(--tt-c2)",
        "--text-success-on-success": "var(--tt-on-c2)",
        "--text-warning": "var(--tt-c1)",
        "--text-contrast": "var(--tt-inverse-standard)",
        "--text-primary-on-primary": "var(--tt-standard)",
        "--text-primary-on-primary-hover": "var(--tt-standard)",
        "--text-primary-on-primary-disabled": "color-mix(in srgb, var(--tt-standard) 55%, transparent)",
        "--theme-submit-btn-bg": "var(--tt-c4)",
        "--theme-submit-btn-text": "var(--tt-on-c4)",
        "--theme-user-msg-bg": "var(--tt-c4)",
        "--theme-user-msg-text": "var(--tt-on-c4)",
        "--border-primary": "var(--tt-outline)",
        "--border-secondary": "var(--tt-outline-variant)",
        "--border-tertiary": "color-mix(in srgb, var(--tt-outline) 30%, transparent)",
        "--search-background": "var(--tt-low)",
        "--search-border-color": "var(--tt-outline)",
        "--search-text-color": "var(--tt-standard)",
        "--overlay-background": "var(--tt-scrim)",
        "--popup-background": "var(--tt-high)",
        "--popup-border": "var(--tt-outline-variant)",
        "--code-background": "var(--tt-low)",
        "--selection-background": "color-mix(in srgb, var(--tt-c4) 30%, transparent)",
        "--component-background": "var(--tt-base)",
        "--component-border": "var(--tt-outline-variant)",
        "--focus-ring-color": "var(--tt-c4)",
        "--link-color": "var(--tt-c4)",
        "--link-hover-color": "color-mix(in srgb, var(--tt-c4) 85%, var(--tt-standard) 15%)",
        "--icon-color": "var(--tt-standard)",
        "--icon-secondary": "var(--tt-muted)"
      }
    },
    {
      "selector": ".bg-token-bg-primary",
      "important": true,
      "set": { "background-color": "var(--tt-base)", "color": "var(--tt-standard)" }
    },
    {
      "selector": ".bg-token-main-surface-primary",
      "important": true,
      "set": { "background-color": "var(--tt-low)" }
    },
    {
      "selector": ".bg-token-main-surface-secondary",
      "important": true,
      "set": { "background-color": "var(--tt-base)" }
    },
    {
      "selector": ".bg-token-main-surface-tertiary",
      "important": true,
      "set": { "background-color": "var(--tt-high)" }
    },
    {
      "selector": ".bg-token-sidebar-surface-primary",
      "important": true,
      "set": { "background-color": "var(--tt-low)" }
    },
    {
      "selector": ".bg-token-sidebar-surface-secondary",
      "important": true,
      "set": { "background-color": "var(--tt-base)" }
    },
    {
      "selector": ".bg-token-sidebar-surface-tertiary",
      "important": true,
      "set": { "background-color": "var(--tt-high)" }
    },
    {
      "selector": ".text-token-text-primary",
      "important": true,
      "set": { "color": "var(--tt-standard)" }
    },
    {
      "selector": ".text-token-text-secondary",
      "important": true,
      "set": { "color": "var(--tt-muted)" }
    },
    {
      "selector": ".text-token-text-tertiary",
      "important": true,
      "set": { "color": "color-mix(in srgb, var(--tt-muted) 60%, transparent)" }
    },
    {
      "selector": ".border-token-border-primary",
      "important": true,
      "set": { "border-color": "var(--tt-outline)" }
    },
    {
      "selector": ".border-token-border-secondary",
      "important": true,
      "set": { "border-color": "var(--tt-outline-variant)" }
    },
    {
      "selector": ".popover",
      "important": true,
      "set": { "background-color": "var(--tt-high)" }
    }
  ]
}
