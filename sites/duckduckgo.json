{
  "version": 2,
  "match": ["*://duckduckgo.com/*"],
  "api": {
    "type": "ddg",
    "set": {
      "k7": "var(--tt-bottom)",
      "kj": "var(--tt-low)",
      "k9": "var(--tt-standard)",
      "k8": "var(--tt-muted)",
      "kx": "var(--tt-c4)",
      "kaa": "color-mix(in srgb, var(--tt-c4) 60%, var(--tt-muted))",
      "k21": "color-mix(in srgb, var(--tt-standard) 8%, transparent)"
    }
  }
}
