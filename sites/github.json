{
  "version": 2,
  "match": ["*://github.com/*"],
  "rules": [
    {
      "selector": ":root",
      "important": true,
      "set": {
        "--bgColor-default": "var(--tt-base)",
        "--bgColor-muted": "var(--tt-low)",
        "--bgColor-inset": "var(--tt-low)",
        "--bgColor-emphasis": "var(--tt-low)",
        "--bgColor-disabled": "var(--tt-low)",
        "--bgColor-transparent": "transparent",
        "--fgColor-default": "var(--tt-standard)",
        "--fgColor-muted": "var(--tt-muted)",
        "--fgColor-neutral": "var(--tt-muted)",
        "--fgColor-disabled": "var(--tt-muted)",
        "--fgColor-onEmphasis": "var(--tt-standard)",
        "--borderColor-default": "var(--tt-outline)",
        "--borderColor-muted": "var(--tt-outline-variant)",
        "--borderColor-emphasis": "var(--tt-outline)",
        "--borderColor-disabled": "transparent",
        "--borderColor-translucent": "transparent",
        "--overlay-bgColor": "var(--tt-high)",
        "--tooltip-bgColor": "var(--tt-high)",
        "--selection-bgColor": "color-mix(in srgb, var(--tt-c4) 40%, transparent)",
        "--focus-outlineColor": "var(--tt-c4)",
        "--fgColor-accent": "var(--tt-c4)",
        "--fgColor-link": "var(--tt-c4)",
        "--bgColor-accent-emphasis": "color-mix(in srgb, var(--tt-c4) 72%, transparent)",
        "--bgColor-accent-muted": "color-mix(in srgb, var(--tt-c4) 12%, transparent)",
        "--borderColor-accent-emphasis": "var(--tt-c4)",
        "--borderColor-accent-muted": "color-mix(in srgb, var(--tt-c4) 40%, transparent)",
        "--fgColor-success": "var(--tt-c2)",
        "--bgColor-success-emphasis": "var(--tt-c2)",
        "--bgColor-success-muted": "color-mix(in srgb, var(--tt-c2) 18%, transparent)",
        "--borderColor-success-emphasis": "var(--tt-c2)",
        "--borderColor-success-muted": "color-mix(in srgb, var(--tt-c2) 45%, transparent)",
        "--fgColor-danger": "var(--tt-error)",
        "--bgColor-danger-emphasis": "var(--tt-error)",
        "--bgColor-danger-muted": "color-mix(in srgb, var(--tt-error) 18%, transparent)",
        "--borderColor-danger-emphasis": "var(--tt-error)",
        "--borderColor-danger-muted": "color-mix(in srgb, var(--tt-error) 45%, transparent)",
        "--fgColor-attention": "var(--tt-c1)",
        "--bgColor-attention-emphasis": "var(--tt-c1)",
        "--bgColor-attention-muted": "color-mix(in srgb, var(--tt-c1) 18%, transparent)",
        "--borderColor-attention-emphasis": "var(--tt-c1)",
        "--borderColor-attention-muted": "color-mix(in srgb, var(--tt-c1) 45%, transparent)",
        "--fgColor-severe": "var(--tt-c3)",
        "--bgColor-severe-emphasis": "var(--tt-c3)",
        "--bgColor-severe-muted": "color-mix(in srgb, var(--tt-c3) 18%, transparent)",
        "--borderColor-severe-emphasis": "var(--tt-c3)",
        "--borderColor-severe-muted": "color-mix(in srgb, var(--tt-c3) 45%, transparent)",
        "--fgColor-done": "var(--tt-c0)",
        "--bgColor-done-emphasis": "var(--tt-c0)",
        "--bgColor-done-muted": "color-mix(in srgb, var(--tt-c0) 18%, transparent)",
        "--borderColor-done-emphasis": "var(--tt-c0)",
        "--borderColor-done-muted": "color-mix(in srgb, var(--tt-c0) 45%, transparent)",
        "--fgColor-sponsors": "var(--tt-c3)",
        "--bgColor-sponsors-emphasis": "var(--tt-c3)",
        "--bgColor-sponsors-muted": "color-mix(in srgb, var(--tt-c3) 18%, transparent)",
        "--borderColor-sponsors-emphasis": "var(--tt-c3)",
        "--borderColor-sponsors-muted": "color-mix(in srgb, var(--tt-c3) 45%, transparent)",
        "--button-primary-bgColor-rest": "var(--tt-c4)",
        "--button-primary-bgColor-hover": "color-mix(in srgb, var(--tt-c4) 88%, var(--tt-standard) 12%)",
        "--button-primary-bgColor-active": "color-mix(in srgb, var(--tt-c4) 80%, var(--tt-standard) 20%)",
        "--button-primary-bgColor-disabled": "color-mix(in srgb, var(--tt-c4) 45%, transparent)",
        "--button-primary-fgColor-rest": "var(--tt-on-c4)",
        "--button-primary-fgColor-disabled": "color-mix(in srgb, var(--tt-on-c4) 55%, transparent)",
        "--button-primary-borderColor-rest": "color-mix(in srgb, var(--tt-c4) 70%, var(--tt-standard) 30%)",
        "--button-primary-borderColor-hover": "color-mix(in srgb, var(--tt-c4) 62%, var(--tt-standard) 38%)",
        "--button-primary-borderColor-active": "color-mix(in srgb, var(--tt-c4) 55%, var(--tt-standard) 45%)",
        "--button-primary-borderColor-disabled": "transparent",
        "--button-primary-shadow-selected": "0px 0px 0px 0px transparent",
        "--button-default-bgColor-rest": "var(--tt-low)",
        "--button-default-bgColor-hover": "var(--tt-base)",
        "--button-default-bgColor-active": "var(--tt-high)",
        "--button-default-bgColor-disabled": "var(--tt-low)",
        "--button-default-fgColor-rest": "var(--tt-standard)",
        "--button-default-borderColor-rest": "var(--tt-outline-variant)",
        "--button-default-borderColor-hover": "var(--tt-outline)",
        "--button-default-borderColor-active": "var(--tt-outline)",
        "--button-default-shadow-resting": "0px 0px 0px 0px transparent",
        "--button-outline-fgColor-rest": "var(--tt-c4)",
        "--button-outline-fgColor-hover": "var(--tt-c4)",
        "--button-outline-fgColor-disabled": "color-mix(in srgb, var(--tt-c4) 45%, transparent)",
        "--button-outline-fgColor-active": "var(--tt-on-c4)",
        "--button-outline-bgColor-rest": "transparent",
        "--button-outline-bgColor-hover": "color-mix(in srgb, var(--tt-c4) 12%, transparent)",
        "--button-outline-bgColor-active": "var(--tt-c4)",
        "--button-outline-shadow-selected": "0px 0px 0px 0px transparent",
        "--button-danger-fgColor-rest": "var(--tt-error)",
        "--button-danger-fgColor-hover": "var(--tt-on-error)",
        "--button-danger-fgColor-active": "var(--tt-on-error)",
        "--button-danger-fgColor-disabled": "color-mix(in srgb, var(--tt-error) 45%, transparent)",
        "--button-danger-bgColor-rest": "transparent",
        "--button-danger-bgColor-hover": "var(--tt-error)",
        "--button-danger-bgColor-active": "color-mix(in srgb, var(--tt-error) 85%, var(--tt-standard) 15%)",
        "--button-danger-bgColor-disabled": "transparent",
        "--button-danger-borderColor-rest": "color-mix(in srgb, var(--tt-error) 60%, transparent)",
        "--button-danger-borderColor-hover": "var(--tt-error)",
        "--button-danger-borderColor-active": "var(--tt-error)",
        "--button-danger-iconColor-rest": "var(--tt-error)",
        "--button-danger-iconColor-hover": "var(--tt-on-error)",
        "--button-danger-shadow-selected": "0px 0px 0px 0px transparent",
        "--button-inactive-bgColor": "transparent",
        "--button-inactive-fgColor": "var(--tt-muted)",
        "--button-invisible-bgColor-rest": "transparent",
        "--button-invisible-bgColor-hover": "color-mix(in srgb, var(--tt-standard) 8%, transparent)",
        "--button-invisible-bgColor-active": "color-mix(in srgb, var(--tt-standard) 12%, transparent)",
        "--button-invisible-bgColor-disabled": "transparent",
        "--button-invisible-iconColor-rest": "var(--tt-muted)",
        "--button-invisible-iconColor-hover": "var(--tt-standard)",
        "--button-invisible-iconColor-disabled": "color-mix(in srgb, var(--tt-muted) 45%, transparent)",
        "--button-invisible-fgColor-rest": "var(--tt-standard)",
        "--button-invisible-fgColor-hover": "var(--tt-standard)",
        "--button-invisible-fgColor-active": "var(--tt-standard)",
        "--button-invisible-fgColor-disabled": "color-mix(in srgb, var(--tt-standard) 45%, transparent)",
        "--button-invisible-borderColor-rest": "transparent",
        "--button-invisible-borderColor-hover": "transparent",
        "--button-invisible-borderColor-active": "transparent",
        "--button-invisible-borderColor-disabled": "transparent",
        "--control-bgColor-rest": "var(--tt-low)",
        "--control-bgColor-hover": "var(--tt-base)",
        "--control-bgColor-active": "var(--tt-high)",
        "--control-bgColor-disabled": "var(--tt-low)",
        "--control-bgColor-selected": "var(--tt-base)",
        "--control-fgColor-rest": "var(--tt-standard)",
        "--control-fgColor-placeholder": "var(--tt-muted)",
        "--control-fgColor-disabled": "color-mix(in srgb, var(--tt-standard) 45%, transparent)",
        "--control-iconColor-rest": "var(--tt-muted)",
        "--control-borderColor-rest": "var(--tt-outline-variant)",
        "--control-borderColor-emphasis": "var(--tt-outline)",
        "--control-borderColor-selected": "var(--tt-c4)",
        "--control-borderColor-disabled": "color-mix(in srgb, var(--tt-outline) 25%, transparent)",
        "--control-checked-bgColor-rest": "var(--tt-c4)",
        "--control-checked-bgColor-hover": "color-mix(in srgb, var(--tt-c4) 88%, var(--tt-standard) 12%)",
        "--control-checked-bgColor-active": "color-mix(in srgb, var(--tt-c4) 80%, var(--tt-standard) 20%)",
        "--control-checked-bgColor-disabled": "color-mix(in srgb, var(--tt-c4) 45%, transparent)",
        "--control-checked-fgColor-rest": "var(--tt-on-c4)",
        "--control-checked-fgColor-disabled": "color-mix(in srgb, var(--tt-on-c4) 55%, transparent)",
        "--control-checked-borderColor-rest": "var(--tt-c4)",
        "--control-checked-borderColor-hover": "var(--tt-c4)",
        "--control-checked-borderColor-active": "var(--tt-c4)",
        "--control-checked-borderColor-disabled": "transparent",
        "--controlTrack-bgColor-rest": "var(--tt-base)",
        "--controlTrack-bgColor-hover": "var(--tt-high)",
        "--controlTrack-bgColor-active": "var(--tt-high)",
        "--controlTrack-bgColor-disabled": "var(--tt-low)",
        "--controlTrack-borderColor-rest": "var(--tt-outline-variant)",
        "--controlTrack-borderColor-disabled": "color-mix(in srgb, var(--tt-outline) 25%, transparent)",
        "--controlTrack-fgColor-rest": "var(--tt-muted)",
        "--controlTrack-fgColor-disabled": "color-mix(in srgb, var(--tt-muted) 45%, transparent)"
      }
    }
  ]
}
