{
  "version": 2,
  "match": ["*://www.youtube.com/*", "*://youtube.com/*"],
  "rules": [
    {
      "selector": ":root",
      "important": true,
      "set": {
        "--yt-spec-base-background": "var(--tt-base)",
        "--yt-spec-raised-background": "var(--tt-high)",
        "--yt-spec-additive-background": "color-mix(in srgb, var(--tt-standard) 5%, transparent)",
        "--yt-spec-additive-background-inverse": "color-mix(in srgb, var(--tt-base) 5%, transparent)",
        "--yt-spec-solid-background": "var(--tt-standard)",
        "--yt-spec-solid-background-inverse": "var(--tt-low)",
        "--yt-spec-text-primary": "var(--tt-standard)",
        "--yt-spec-text-secondary": "var(--tt-muted)",
        "--yt-spec-text-disabled": "color-mix(in srgb, var(--tt-standard) 50%, transparent)",
        "--yt-spec-text-primary-inverse": "var(--tt-base)",
        "--yt-spec-text-secondary-inverse": "color-mix(in srgb, var(--tt-base) 70%, var(--tt-standard) 30%)",
        "--yt-spec-outline": "var(--tt-outline)",
        "--yt-spec-outline-opaque": "var(--tt-outline)",
        "--yt-spec-outline-rim": "color-mix(in srgb, var(--tt-outline) 30%, transparent)",
        "--yt-spec-outline-inverse": "color-mix(in srgb, var(--tt-outline) 50%, var(--tt-base) 50%)",
        "--yt-spec-outline-rim-inverse": "color-mix(in srgb, var(--tt-outline) 15%, transparent)",
        "--yt-spec-outline-opaque-inverse": "color-mix(in srgb, var(--tt-outline) 40%, var(--tt-base) 60%)",
        "--yt-spec-link-icon-color": "var(--tt-c4)",
        "--yt-spec-wordmark-text": "var(--tt-standard)",
        "--yt-spec-call-to-action": "var(--tt-c4)",
        "--yt-spec-brand-button-background": "var(--tt-c4)",
        "--yt-spec-brand-button-text": "var(--tt-on-c4)",
        "--yt-spec-brand-link-text": "var(--tt-c4)",
        "--yt-spec-error-background": "color-mix(in srgb, var(--tt-error) 20%, transparent)",
        "--yt-spec-text-warning": "var(--tt-c1)",
        "--yt-spec-background-warning": "color-mix(in srgb, var(--tt-c1) 20%, transparent)",
        "--yt-spec-background-complete": "color-mix(in srgb, var(--tt-c2) 15%, transparent)",
        "--yt-spec-text-complete": "var(--tt-c2)",
        "--yt-spec-overlay-background-heavy": "var(--tt-scrim)",
        "--yt-spec-overlay-background-medium": "color-mix(in srgb, var(--tt-scrim) 60%, transparent)",
        "--yt-spec-overlay-background-medium-light": "color-mix(in srgb, var(--tt-scrim) 30%, transparent)",
        "--yt-spec-overlay-background-light": "color-mix(in srgb, var(--tt-standard) 8%, transparent)",
        "--yt-spec-overlay-background-medium-heavy": "color-mix(in srgb, var(--tt-scrim) 80%, transparent)",
        "--yt-spec-overlay-background-brand": "color-mix(in srgb, var(--tt-c4) 90%, transparent)",
        "--yt-spec-overlay-solid-background": "var(--tt-low)",
        "--yt-spec-overlay-solid-background-inverse": "var(--tt-standard)",
        "--yt-spec-button-chip-background-hover": "color-mix(in srgb, var(--tt-standard) 10%, transparent)",
        "--yt-spec-tonal-background": "color-mix(in srgb, var(--tt-standard) 10%, transparent)",
        "--yt-spec-tonal-background-inverse": "color-mix(in srgb, var(--tt-base) 10%, transparent)",
        "--yt-spec-inverted-background": "var(--tt-inverse-base)",
        "--yt-spec-inverted-background-hover": "color-mix(in srgb, var(--tt-inverse-base) 85%, var(--tt-inverse-standard) 15%)",
        "--yt-spec-scrim-background-gradient-1": "transparent",
        "--yt-spec-scrim-background-gradient-2": "color-mix(in srgb, var(--tt-base) 30%, transparent)",
        "--yt-spec-scrim-background-gradient-3": "color-mix(in srgb, var(--tt-base) 60%, transparent)",
        "--yt-spec-scrim-background-gradient-4": "var(--tt-base)",
        "--yt-spec-snackbar-background": "var(--tt-standard)",
        "--yt-spec-snackbar-text": "var(--tt-base)",
        "--yt-spec-10-percent-layer": "color-mix(in srgb, var(--tt-standard) 10%, transparent)",
        "--yt-spec-15-percent-layer": "color-mix(in srgb, var(--tt-standard) 15%, transparent)",
        "--yt-spec-20-percent-layer": "color-mix(in srgb, var(--tt-standard) 20%, transparent)",
        "--yt-spec-30-percent-layer": "color-mix(in srgb, var(--tt-standard) 30%, transparent)",
        "--yt-spec-40-percent-layer": "color-mix(in srgb, var(--tt-standard) 40%, transparent)",
        "--yt-spec-50-percent-layer": "color-mix(in srgb, var(--tt-standard) 50%, transparent)",
        "--yt-spec-60-percent-layer": "color-mix(in srgb, var(--tt-standard) 60%, transparent)",
        "--yt-spec-70-percent-layer": "color-mix(in srgb, var(--tt-standard) 70%, transparent)",
        "--yt-spec-80-percent-layer": "color-mix(in srgb, var(--tt-standard) 80%, transparent)",
        "--yt-spec-90-percent-layer": "color-mix(in srgb, var(--tt-standard) 90%, transparent)",
        "--yt-spec-suggested-action-background": "var(--tt-high)",
        "--yt-spec-suggested-action-background-hover": "var(--tt-top)",
        "--yt-spec-menu-button-background": "transparent",
        "--yt-spec-badge-chip-background": "var(--tt-high)",
        "--yt-spec-badge-chip-background-hover": "var(--tt-top)",
        "--yt-spec-static-overlay-background-heavy": "var(--tt-scrim)",
        "--yt-spec-static-overlay-background-medium": "color-mix(in srgb, var(--tt-scrim) 60%, transparent)",
        "--yt-spec-static-overlay-background-medium-light": "color-mix(in srgb, var(--tt-scrim) 30%, transparent)",
        "--yt-spec-static-overlay-background-light": "color-mix(in srgb, var(--tt-standard) 8%, transparent)",
        "--yt-spec-static-overlay-background-medium-heavy": "color-mix(in srgb, var(--tt-scrim) 80%, transparent)",
        "--yt-spec-static-brand-red": "var(--tt-error)",
        "--yt-spec-static-overlay-solid-background": "var(--tt-standard)",
        "--yt-searchbox-background": "var(--tt-low)",
        "--yt-searchbox-text-color": "var(--tt-standard)",
        "--yt-searchbox-legacy-border-color": "var(--tt-outline)",
        "--yt-searchbox-legacy-button-color": "var(--tt-standard)",
        "--yt-spec-general-background-a": "var(--tt-base)",
        "--yt-spec-general-background-b": "var(--tt-low)",
        "--yt-spec-general-background-c": "var(--tt-high)",
        "--paper-slider-container-color": "color-mix(in srgb, var(--tt-standard) 15%, transparent)",
        "--paper-slider-container-color-2": "color-mix(in srgb, var(--tt-standard) 30%, transparent)",
        "--paper-slider-knob-color": "var(--tt-standard)",
        "--paper-slider-pin-color": "var(--tt-c4)",
        "--paper-slider-active-color": "var(--tt-c4)",
        "--paper-slider-secondary-color": "color-mix(in srgb, var(--tt-c4) 40%, transparent)",
        "--paper-slider-disabled-active-color": "color-mix(in srgb, var(--tt-standard) 25%, transparent)",
        "--paper-slider-disabled-secondary-color": "color-mix(in srgb, var(--tt-standard) 15%, transparent)",
        "--ytd-menu-popup-header-bg": "var(--tt-low)"
      }
    }
  ]
}
